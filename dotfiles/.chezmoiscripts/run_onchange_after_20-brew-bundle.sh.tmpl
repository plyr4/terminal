#!/usr/bin/env bash
# install Homebrew packages. re-runs automatically whenever the Brewfile changes.
set -euo pipefail
{{ if eq .chezmoi.os "darwin" -}}

# make brew available (apple silicon or intel)
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Brewfile hash: {{ include (joinPath .chezmoi.sourceDir ".." "Brewfile") | sha256sum }}
# trust all taps declared in the Brewfile before bundling
grep -E '^tap "' {{ joinPath .chezmoi.sourceDir ".." "Brewfile" | quote }} \
  | sed 's/tap "\([^"]*\)".*/\1/' \
  | while IFS= read -r t; do
      brew trust "$t" 2>/dev/null || true
    done

echo "installing Homebrew packages from Brewfile..."
brew bundle --file={{ joinPath .chezmoi.sourceDir ".." "Brewfile" | quote }}
{{ $local := joinPath .chezmoi.sourceDir ".." "Brewfile.local" -}}
{{ if stat $local }}
# optional machine-local packages (git-ignored)
# Brewfile.local hash: {{ include $local | sha256sum }}
brew bundle --file={{ $local | quote }}
{{ end -}}
{{ end -}}
