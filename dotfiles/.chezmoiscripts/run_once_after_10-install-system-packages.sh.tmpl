#!/usr/bin/env bash
# install base system prerequisites. runs once per machine.
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
# xcode command line tools
if ! xcode-select -p >/dev/null 2>&1; then
  echo "installing xcode command line tools..."
  xcode-select --install || true
  echo "re-run 'chezmoi apply' once the tools have finished installing."
  exit 0
fi

# homebrew
if ! command -v brew >/dev/null 2>&1 \
  && [ ! -x /opt/homebrew/bin/brew ] && [ ! -x /usr/local/bin/brew ]; then
  echo "installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
{{ else if eq .chezmoi.os "linux" -}}
go_version="${GO_VERSION:-1.22.5}"

echo "installing base apt packages..."
sudo apt-get update
sudo apt-get install -y \
  build-essential ca-certificates colordiff curl git git-lfs gnupg jq \
  lsb-release ripgrep tmux tree vim xclip

# go from the official tarball when missing or out of date
if ! command -v go >/dev/null 2>&1 || [ "$(go version | awk '{print $3}')" != "go${go_version}" ]; then
  echo "installing go ${go_version}..."
  tmp="$(mktemp -d)"
  curl -fsSL "https://go.dev/dl/go${go_version}.linux-amd64.tar.gz" -o "$tmp/go.tar.gz"
  sudo rm -rf /usr/local/go
  sudo tar -C /usr/local -xzf "$tmp/go.tar.gz"
  rm -rf "$tmp"
fi

# docker engine via the official convenience script
if ! command -v docker >/dev/null 2>&1; then
  echo "installing docker..."
  curl -fsSL https://get.docker.com | sh
fi
{{ end -}}
